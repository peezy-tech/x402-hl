{
  "name": "x402-hl-express-example",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Standalone Express example for accepting Hyperliquid x402 payments.",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "start": "tsx --env-file=.env src/server.ts",
    "typecheck": "tsc --noEmit",
    "smoke": "tsx --env-file=.env scripts/smoke.ts",
    "pay": "tsx --env-file=.env scripts/pay-once.ts"
  },
  "dependencies": {
    "@x402/core": "^2.14.0",
    "@x402/express": "^2.14.0",
    "@x402/fetch": "^2.14.0",
    "@x402/paywall": "^2.14.0",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "viem": "^2.39.3",
    "x402-hl": "file:../.."
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=24"
  }
}
