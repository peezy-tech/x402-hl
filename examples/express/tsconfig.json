{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "noEmit": true,
    "baseUrl": "../..",
    "paths": {
      "x402-hl": ["src/index.ts"],
      "x402-hl/exact/client": ["src/exact/client/index.ts"],
      "x402-hl/exact/server": ["src/exact/server/index.ts"],
      "x402-hl/exact/facilitator": ["src/exact/facilitator/index.ts"],
      "x402-hl/paywall": ["src/paywall/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "scripts/**/*.ts"]
}
