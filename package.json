{
  "name": "x402-hl",
  "version": "0.1.1",
  "type": "module",
  "description": "Standalone Hyperliquid primitives and injected-wallet paywall for x402.",
  "license": "MIT",
  "author": "Peezy",
  "homepage": "https://github.com/peezy-tech/x402-hl#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peezy-tech/x402-hl.git"
  },
  "bugs": {
    "url": "https://github.com/peezy-tech/x402-hl/issues"
  },
  "keywords": [
    "x402",
    "hyperliquid",
    "payments",
    "paywall",
    "http-402"
  ],
  "scripts": {
    "build": "pnpm build:paywall && tsup",
    "build:paywall": "tsx src/paywall/build.ts",
    "compat:all": "pnpm compat:payment-identifier && pnpm compat:offer-receipt && pnpm compat:siwx && pnpm compat:mcp-axios",
    "compat:mcp-axios": "tsx examples/compat/mcp-axios.ts",
    "compat:offer-receipt": "tsx examples/compat/offer-receipt.ts",
    "compat:payment-identifier": "tsx examples/compat/payment-identifier.ts",
    "compat:siwx": "tsx examples/compat/siwx.ts",
    "docs:build": "pnpm --dir docs build",
    "docs:check": "pnpm --dir docs check:types",
    "docs:dev": "pnpm --dir docs dev",
    "example:express:typecheck": "tsc -p examples/express/tsconfig.json",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.examples.json"
  },
  "dependencies": {
    "@nktkas/hyperliquid": "^0.25.9",
    "@tanstack/react-query": "^5.90.7",
    "@wagmi/connectors": "^5.8.1",
    "@x402/core": "^2.14.0",
    "@x402/paywall": "^2.14.0",
    "buffer": "^6.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "viem": "^2.39.3",
    "wagmi": "^2.17.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@craftamap/esbuild-plugin-html": "^0.9.0",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@x402/axios": "^2.14.0",
    "@x402/express": "^2.14.0",
    "@x402/extensions": "^2.14.0",
    "@x402/fetch": "^2.14.0",
    "axios": "^1.16.0",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "esbuild": "^0.25.4",
    "tsup": "^8.4.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./exact/client": {
      "import": {
        "types": "./dist/exact/client/index.d.ts",
        "default": "./dist/exact/client/index.js"
      }
    },
    "./exact/server": {
      "import": {
        "types": "./dist/exact/server/index.d.ts",
        "default": "./dist/exact/server/index.js"
      }
    },
    "./exact/facilitator": {
      "import": {
        "types": "./dist/exact/facilitator/index.d.ts",
        "default": "./dist/exact/facilitator/index.js"
      }
    },
    "./paywall": {
      "import": {
        "types": "./dist/paywall/index.d.ts",
        "default": "./dist/paywall/index.js"
      }
    }
  },
  "files": [
    "dist",
    "src/paywall/gen"
  ],
  "engines": {
    "node": ">=24"
  }
}
